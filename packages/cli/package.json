{
  "name": "@romeo/cli",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "bin": {
    "romeo": "./bin/romeo.mjs"
  },
  "files": [
    "bin",
    "src/**/*.ts",
    "!src/**/*.test.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@romeo/api-client": "workspace:*",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
