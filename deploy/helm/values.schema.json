        },
        "NOTIFICATION_EMAIL_FROM": {
          "type": "string"
        },
        "NOTIFICATION_FCM_BASE_URL": {
          "type": "string",
          "pattern": "^https?://.+$"
        },
        "NOTIFICATION_FCM_PROJECT_ID": {
          "type": "string"
        },
        "NOTIFICATION_FCM_SERVICE_ACCOUNT_REF": {
          "type": "string"
        },
        "NOTIFICATION_FCM_TIMEOUT_MS": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[1-9][0-9]*$" }
          ]
        },
