        "NOTIFICATION_PAGERDUTY_EVENTS_URL": {
          "type": "string",
          "pattern": "^https?://.+$"
        },
        "NOTIFICATION_PAGERDUTY_TIMEOUT_MS": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[1-9][0-9]*$" }
          ]
        },
        "NOTIFICATION_RESEND_BASE_URL": {
          "type": "string",
          "pattern": "^https?://.+$"
        },
        "NOTIFICATION_RESEND_TIMEOUT_MS": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[1-9][0-9]*$" }
          ]
        },
        "NOTIFICATION_SLACK_TIMEOUT_MS": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[1-9][0-9]*$" }
          ]
        },
