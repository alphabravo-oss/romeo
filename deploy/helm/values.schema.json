        "BROWSER_AUTOMATION_TIMEOUT_MS": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[1-9][0-9]*$" }
          ]
        },
        "BROWSER_AUTOMATION_MAX_BYTES": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[1-9][0-9]*$" }
          ]
        },
        "SCIM_ENABLED": {
          "type": "string",
          "enum": ["true", "false"]
        },
        "EXTERNAL_VECTOR_STORE_DRIVER": {
          "type": "string",
          "enum": ["disabled", "qdrant"]
        },
        "QDRANT_URL": {
          "type": "string",
          "pattern": "^$|^https?://.+$"
        },
        "QDRANT_COLLECTION": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "QDRANT_TIMEOUT_MS": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[1-9][0-9]*$" }
          ]
        },
        "VECTOR_NAMESPACE_POLICY": {
          "type": "string",
          "enum": ["none", "org", "workspace", "knowledge_base"]
        },
        "VECTOR_PARTITIONING_POLICY": {
          "type": "string",
          "enum": ["none", "org", "workspace", "knowledge_base"]
        },
        "VECTOR_ISOLATION_MODE": {
          "type": "string",
          "enum": [
            "shared_row_scope",
            "pgvector_partitioned_by_org",
            "external_namespace_per_org",
            "external_collection_per_org",
            "dedicated_vector_store_per_org"
          ]
        },
        "PGVECTOR_PHYSICAL_ISOLATION_EVIDENCE_PATH": {
          "type": "string"
        },
        "QDRANT_LIVE_EVIDENCE_PATH": {
          "type": "string"
        },
        "DELEGATED_OAUTH_GITHUB_CLIENT_ID": {
          "type": "string"
        },
        "DELEGATED_OAUTH_GITHUB_SCOPES": {
          "type": "string",
          "pattern": "^$|^[A-Za-z0-9_:./-]+(,[A-Za-z0-9_:./-]+)*$"
        },
        "TOOL_OPERATION_EXECUTION_DRIVER": {
          "type": "string",
          "enum": ["disabled", "http-fetch"]
        },
        "TOOL_OPERATION_FETCH_TIMEOUT_MS": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[1-9][0-9]*$" }
          ]
        },
        "TOOL_OPERATION_FETCH_MAX_BYTES": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[1-9][0-9]*$" }
          ]
        },
        "TOOL_DISPATCH_PAYLOAD_STORE_DRIVER": {
          "type": "string",
          "enum": ["disabled", "object-store"]
        },
        "TOOL_DISPATCH_PAYLOAD_STORE_PREFIX": {
          "type": "string",
          "minLength": 1
        },
        "DATA_CONNECTOR_FETCH_RETRY_ATTEMPTS": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 5 },
            { "type": "string", "pattern": "^[0-5]$" }
          ]
        },
        "DATA_CONNECTOR_FETCH_RETRY_BACKOFF_MS": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 60000 },
            {
              "type": "string",
              "pattern": "^(0|[1-9][0-9]{0,3}|[1-5][0-9]{4}|60000)$"
            }
          ]
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "targetMemoryUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    },
    "evidenceMount": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 63,
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "mountPath": {
          "type": "string",
          "minLength": 2,
          "pattern": "^/.*$"
        },
        "configMapName": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
        },
        "secretName": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
        }
      }
    },
    "workers": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "apiKeySecret": {
          "$ref": "#/$defs/secretKeyRef"
        },
        "dataConnectorSync": { "$ref": "#/$defs/workerToggle" },
        "workflowResume": { "$ref": "#/$defs/workerToggle" },
        "webhookRetry": { "$ref": "#/$defs/workerToggle" },
        "notificationRetry": { "$ref": "#/$defs/workerToggle" },
        "retentionEnforce": { "$ref": "#/$defs/workerToggle" },
        "billingEntitlementReconcile": { "$ref": "#/$defs/workerToggle" },
        "billingLifecycleEnforce": { "$ref": "#/$defs/workerToggle" },
        "toolDispatch": {
          "allOf": [{ "$ref": "#/$defs/workerToggle" }],
          "properties": {
            "maxJobs": { "type": "integer", "minimum": 1 },
            "leaseSeconds": { "type": "integer", "minimum": 1 },
            "timeoutMs": { "type": "integer", "minimum": 1 },
            "maxBytes": { "type": "integer", "minimum": 1 },
            "allowPrivateNetwork": { "type": "boolean" },
            "secretResolverDriver": {
              "type": "string",
              "enum": [
                "disabled",
                "env",
                "vault",
                "aws-sm",
                "gcp-sm",
                "azure-kv",
                "cloud"
              ]
            },
            "payloadSecret": {
              "$ref": "#/$defs/secretKeyRef"
            },
            "networkPolicy": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "enabled": { "type": "boolean" },
                "egress": { "type": "array" }
              }
            }
          }
        },
        "browserAutomation": {
          "allOf": [{ "$ref": "#/$defs/workerToggle" }],
          "properties": {
            "runnerUrl": {
              "type": "string"
            },
            "maxJobs": { "type": "integer", "minimum": 1 },
            "leaseSeconds": { "type": "integer", "minimum": 1 },
            "timeoutMs": { "type": "integer", "minimum": 1 },
            "maxBytes": { "type": "integer", "minimum": 1 },
            "networkPolicy": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "enabled": { "type": "boolean" },
                "egress": { "type": "array" }
              }
            }
          }
        },
        "knowledgeExtraction": {
          "allOf": [{ "$ref": "#/$defs/workerToggle" }],
          "properties": {
            "knowledgeBaseId": { "type": "string" },
            "maxSources": { "type": "integer", "minimum": 1 }
          }
        },
        "voiceCatalogSync": { "$ref": "#/$defs/workerToggle" }
      }
    },
    "backup": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "schedule": { "type": "string" },
        "retentionDays": { "type": "integer", "minimum": 0 },
        "uploadTimeoutMs": { "type": "integer", "minimum": 1 },
        "uploadUrlSecret": {
          "$ref": "#/$defs/secretKeyRef"
        },
        "manifestUploadUrlSecret": {
          "$ref": "#/$defs/secretKeyRef"
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "ingressFrom": { "type": "array" },
        "egress": { "type": "array" }
      }
    }
  },
  "$defs": {
    "secretKeyRef": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "key": { "type": "string" }
      }
    },
    "workerToggle": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "schedule": { "type": "string" }
      }
    }
  }
}
