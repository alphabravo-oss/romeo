        "AWS_SECRET_MANAGER_TIMEOUT_MS": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[1-9][0-9]*$" }
          ]
        },
        "GCP_SECRET_MANAGER_PROJECT": {
          "type": "string"
        },
        "GCP_SECRET_MANAGER_TIMEOUT_MS": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[1-9][0-9]*$" }
          ]
        },
        "AZURE_KEY_VAULT_URL": {
          "type": "string"
        },
        "AZURE_KEY_VAULT_TIMEOUT_MS": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[1-9][0-9]*$" }
          ]
        },
        "NOTIFICATION_DELIVERY_DRIVER": {
          "type": "string",
