        "KNOWLEDGE_EXTRACTION_TIMEOUT_MS": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[1-9][0-9]*$" }
          ]
        },
        "PDFTOTEXT_PATH": {
          "type": "string",
          "minLength": 1
        },
        "SECRET_RESOLVER_DRIVER": {
          "type": "string",
