            }
          ]
        },
        "FILE_INLINE_MAX_BYTES": {
          "oneOf": [
            { "type": "integer", "minimum": 1, "maximum": 250000000 },
            {
              "type": "string",
              "pattern": "^([1-9][0-9]{0,7}|1[0-9]{8}|2[0-4][0-9]{7}|250000000)$"
            }
          ]
        },
        "FILE_DIRECT_UPLOAD_MAX_BYTES": {
          "oneOf": [
            { "type": "integer", "minimum": 1, "maximum": 1000000000 },
            {
              "type": "string",
              "pattern": "^([1-9][0-9]{0,8}|1000000000)$"
            }
          ]
        },
        "FILE_RESUMABLE_UPLOAD_MAX_BYTES": {
          "oneOf": [
            { "type": "integer", "minimum": 1, "maximum": 5000000000 },
