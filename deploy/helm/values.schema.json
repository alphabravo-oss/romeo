{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "production": { "type": "boolean" }
      }
    },
    "postgres": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["external", "cloudnativepg", "disabled"]
        },
        "databaseUrlSecret": {
          "$ref": "#/$defs/secretKeyRef"
        },
        "cloudnativepg": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "clusterName": { "type": "string" },
            "databaseUrlSecret": {
              "$ref": "#/$defs/secretKeyRef"
            }
          }
        }
      }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "existingSecret": { "type": "string" },
        "create": { "type": "boolean" }
      }
    },
    "migration": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "useHelmHook": { "type": "boolean" },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "ttlSecondsAfterFinished": { "type": "integer", "minimum": 0 },
        "activeDeadlineSeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "env": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "APP_ORIGIN": {
          "type": "string",
          "pattern": "^https?://.+$"
        },
        "REPOSITORY_DRIVER": {
          "type": "string",
          "enum": ["postgres"]
        },
        "OBJECT_STORE_DRIVER": {
          "type": "string",
          "enum": ["s3"]
        },
        "DATA_CONNECTOR_EXECUTION_DRIVER": {
          "type": "string",
          "enum": [
            "disabled",
            "website-fetch",
            "github-fetch",
            "s3-fetch",
            "atlassian-fetch",
            "notion-fetch",
            "linear-fetch",
            "slack-fetch",
            "managed-fetch"
          ]
        },
        "DATA_CONNECTOR_EGRESS_POLICY": {
          "type": "string",
          "enum": ["allow_public", "require_allowlist"]
        },
        "DATA_CONNECTOR_FETCH_ALLOWED_HOSTS": {
          "type": "string"
        },
        "DATA_CONNECTOR_FETCH_MAX_BYTES": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[1-9][0-9]*$" }
          ]
        },
        "DATA_CONNECTOR_FETCH_TIMEOUT_MS": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[1-9][0-9]*$" }
          ]
        },
        "DATA_CONNECTOR_LIVE_EVIDENCE_PATH": {
          "type": "string"
        },
        "DATA_CONNECTOR_WORKER_ENABLED": {
          "type": "string",
          "enum": ["true", "false"]
        },
        "DATA_CONNECTOR_NETWORK_POLICY_ENABLED": {
          "type": "string",
          "enum": ["true", "false"]
        },
        "NOTIFICATION_ADAPTER_LIVE_EVIDENCE_PATH": {
          "type": "string"
        },
        "VOICE_PROVIDER_LIVE_EVIDENCE_PATH": {
          "type": "string"
        },
        "TOOL_DISPATCH_LIVE_EVIDENCE_PATH": {
          "type": "string"
        },
        "TOOL_DISPATCH_WORKER_ENABLED": {
          "type": "string",
          "enum": ["true", "false"]
        },
        "TOOL_DISPATCH_NETWORK_POLICY_ENABLED": {
          "type": "string",
          "enum": ["true", "false"]
        },
        "KNOWLEDGE_EXTRACTION_DRIVER": {
          "type": "string",
          "enum": ["disabled", "local-pdftotext", "local-documents"]
